# 環境變數配置檔案
# 請複製此檔案為 .env 並填入實際值

# OpenAI API 金鑰 (必填)
OPENAI_API_KEY=your_openai_api_key_here

# Flask 環境設定
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your_secret_key_here

# 資料庫設定 (如果使用資料庫)
# DATABASE_URL=sqlite:///app.db

# 日誌設定
LOG_LEVEL=INFO

# 其他 API 金鑰 (如需要)
# GOOGLE_API_KEY=your_google_api_key
# AZURE_API_KEY=your_azure_api_key